<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Whitelist nuget.org as the only package source for management-apps. The
    <clear /> drops any inherited sources from a parent NuGet.Config or user
    config. Supply-chain hardening — prevents accidental private-feed
    dependency injection.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <packageSourceMapping>
    <!-- Every package must come from nuget.org. -->
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
