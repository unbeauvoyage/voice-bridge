# EditorConfig — style + analyzer severities for the management-apps repo.
#
# Severity rules below are SCOPED to the .NET backend services
# (BackendShared, MessageRelay, VoiceBridge, ContentService) via path-based
# globs. AppHost and ServiceDefaults are intentionally NOT under the strict
# regime — they are Aspire infrastructure projects with looser rules.
#
# To opt a future project into strictness: add its folder to the path globs
# below AND have its .csproj import BackendShared/Backends.props.

root = true

# ─── Common (every file) ─────────────────────────────────────────────────────

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{cs,csproj,props,targets,sln,xml,yml,yaml,json}]
indent_size = 2

[*.cs]
indent_size = 4

# ─── Strict regime — backend services only ───────────────────────────────────
# Path glob matches files anywhere under the listed folders. AppHost/* and
# ServiceDefaults/* do NOT match and stay at SDK-default severities.

[{BackendShared,MessageRelay,VoiceBridge,ContentService}/**.cs]

# ─── C# language conventions ──────────────────────────────────────────────────

# File-scoped namespaces — modern, less indentation.
csharp_style_namespace_declarations = file_scoped:error

# Forbid loose `var` — every local must declare its type explicitly. This is the
# closest C# analogue to the TS-side ban on `any`: `var` lets the compiler hide
# the type from a reader; explicit types put the type back in the source.
csharp_style_var_when_type_is_apparent = false:error
csharp_style_var_for_built_in_types = false:error
csharp_style_var_elsewhere = false:error

# Prefer expression-bodied members where the body is a single expression.
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = when_on_single_line:suggestion
csharp_style_expression_bodied_operators = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion

# Brace requirement — Apple-`goto fail` class of bug. IDE0011 backs this up.
csharp_prefer_braces = true:error

# Modern null-handling.
csharp_style_throw_expression = true:error
csharp_style_conditional_delegate_call = true:error

# `using` directives outside the namespace.
csharp_using_directive_placement = outside_namespace:error

# Pattern matching > old-style cast checks.
csharp_style_pattern_matching_over_is_with_cast_check = true:error
csharp_style_pattern_matching_over_as_with_null_check = true:error

# ─── .NET style conventions ───────────────────────────────────────────────────

dotnet_style_qualification_for_field = false:error
dotnet_style_qualification_for_property = false:error
dotnet_style_qualification_for_method = false:error
dotnet_style_qualification_for_event = false:error
dotnet_style_predefined_type_for_locals_parameters_members = true:error
dotnet_style_predefined_type_for_member_access = true:error

# Accessibility modifiers always required (no implicit-internal).
dotnet_style_require_accessibility_modifiers = always:error

# Namespace must match folder structure — prevents Features/Foo/X.cs declaring
# namespace VoiceBridge.Bar, which is a navigation surprise.
dotnet_style_namespace_match_folder = true:error

# ─── IDE rules promoted to error ─────────────────────────────────────────────
# Reachable via AnalysisMode=All today but at default warning. Explicit error
# promotion makes the policy locally readable and stable across analyzer
# version bumps.

dotnet_diagnostic.IDE0005.severity = error  # unused using directive
dotnet_diagnostic.IDE0011.severity = error  # require braces (backs csharp_prefer_braces)
dotnet_diagnostic.IDE0040.severity = error  # accessibility modifier required
dotnet_diagnostic.IDE0044.severity = error  # make field readonly when possible
dotnet_diagnostic.IDE0051.severity = error  # remove unused private member
dotnet_diagnostic.IDE0052.severity = error  # remove unread private member
dotnet_diagnostic.IDE0060.severity = error  # remove unused parameter
dotnet_diagnostic.IDE0079.severity = error  # remove unnecessary suppression — prevents the #pragma escape hatch from silently surviving the underlying fix
dotnet_diagnostic.IDE0301.severity = error  # use collection expression
dotnet_diagnostic.SYSLIB1045.severity = error  # use [GeneratedRegex] (source-gen)

# ─── Nullability — every nullable warning is an error ────────────────────────

dotnet_diagnostic.CS8600.severity = error  # converting null literal to non-nullable
dotnet_diagnostic.CS8601.severity = error  # possible null reference assignment
dotnet_diagnostic.CS8602.severity = error  # dereference of possibly null reference
dotnet_diagnostic.CS8603.severity = error  # possible null reference return
dotnet_diagnostic.CS8604.severity = error  # possible null reference argument
dotnet_diagnostic.CS8618.severity = error  # non-nullable field uninitialized
dotnet_diagnostic.CS8625.severity = error  # cannot convert null to non-nullable

# ─── Banned APIs (Microsoft.CodeAnalysis.BannedApiAnalyzers + BannedSymbols.txt) ─

dotnet_diagnostic.RS0030.severity = error  # symbol is in BannedSymbols.txt

# ─── Banned: `dynamic` keyword (analogue to TS `any`) ────────────────────────
# Enforced via BackendShared/Backends.targets (MSBuild grep target). Followup
# Task #25 replaces the grep with a custom Roslyn analyzer (LSP-grade squiggles).

# ─── Banned: dangerous `as` casts (analogue to TS `as`) ──────────────────────
# Roslynator RCS1206: avoid `as` cast when the value is dereferenced without a
# null check. Pattern-matching `is T t` is the preferred form (see
# csharp_style_pattern_matching_over_as_with_null_check above).
dotnet_diagnostic.RCS1206.severity = error

# ─── Banned: null-forgiving `!` operator (analogue to TS `!`) ────────────────
# BSH0001 fires from BackendShared.Analyzers/NullForgivingBanAnalyzer.cs on
# SyntaxKind.SuppressNullableWarningExpression. Wired as error below.
dotnet_diagnostic.BSH0001.severity = error  # null-forgiving `!` is banned (BackendShared.Analyzers)

# ─── ASP.NET Core specifics — silenced (wrong-context) ───────────────────────
# CA2007 (ConfigureAwait) is wrong for ASP.NET — there is no SyncContext, so
# .ConfigureAwait(false) is a no-op and adds noise. CA1303 (locale-aware logging)
# is wrong for backend services that log non-localized strings.
dotnet_diagnostic.CA2007.severity = none
dotnet_diagnostic.CA1303.severity = none
dotnet_diagnostic.CA1014.severity = none  # CLS-compliance — internal-only services
dotnet_diagnostic.CA1310.severity = none  # StringComparison required — covered by InvariantGlobalization + BannedApi entries on String.Equals/StartsWith/etc.
dotnet_diagnostic.CA1824.severity = none  # NeutralResourcesLanguageAttribute — irrelevant for backend

# ─── Specific CA promotions (explicit > implicit) ────────────────────────────
# All reachable today via AnalysisMode=All but at default warning. Explicit
# error makes the policy locally readable.

dotnet_diagnostic.CA1062.severity = error  # validate args of public methods
dotnet_diagnostic.CA1305.severity = error  # IFormatProvider on numeric/datetime parses
dotnet_diagnostic.CA1707.severity = error  # no underscores in identifiers
dotnet_diagnostic.CA1822.severity = error  # mark members static where possible
dotnet_diagnostic.CA1848.severity = error  # use LoggerMessage source-gen (perf + structured logs)
dotnet_diagnostic.CA1850.severity = error  # prefer SHA256.HashData over CreateHash() — content-service-critical
dotnet_diagnostic.CA1852.severity = error  # seal internal types
dotnet_diagnostic.CA2227.severity = error  # collection properties read-only
dotnet_diagnostic.CA2234.severity = error  # use Uri overloads

# ─── VS Threading Analyzers (sync-over-async, async void) ────────────────────
# CVE-class for ASP.NET Core. The .NET SDK doesn't catch these; this analyzer
# does.

dotnet_diagnostic.VSTHRD002.severity = error  # avoid sync wait on async (.Result, .Wait)
dotnet_diagnostic.VSTHRD003.severity = error  # avoid awaiting foreign Tasks
dotnet_diagnostic.VSTHRD100.severity = error  # avoid async void
dotnet_diagnostic.VSTHRD103.severity = error  # call async version when available
dotnet_diagnostic.VSTHRD110.severity = error  # observe result of async call
dotnet_diagnostic.VSTHRD200.severity = none   # "Async" suffix naming convention — opinion, not correctness

# ─── Meziantou Analyzer (async/cancel/IFormatProvider) ───────────────────────

dotnet_diagnostic.MA0004.severity = none   # ConfigureAwait — wrong for ASP.NET (matches CA2007 silencing)
dotnet_diagnostic.MA0006.severity = error  # use String.Equals(String, StringComparison)
dotnet_diagnostic.MA0011.severity = error  # IFormatProvider missing
dotnet_diagnostic.MA0040.severity = error  # forward CancellationToken
dotnet_diagnostic.MA0042.severity = error  # do not use blocking calls in async
dotnet_diagnostic.MA0045.severity = error  # do not use blocking calls in sync
dotnet_diagnostic.MA0074.severity = error  # avoid implicit string interpolation w/ no params
dotnet_diagnostic.MA0089.severity = error  # default StringComparison

# ─── Documentation — CS1591 silenced via NoWarn in Backends.props ────────────
# Keep CS1574/CS1580/CS1581/CS1584 (broken cref) at error so existing docs
# don't rot silently.

dotnet_diagnostic.CS1574.severity = error
dotnet_diagnostic.CS1580.severity = error
dotnet_diagnostic.CS1581.severity = error
dotnet_diagnostic.CS1584.severity = error
