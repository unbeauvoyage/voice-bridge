{
  "name": "knowledge-base",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "server": "bun run src/server.ts",
    "dev": "bun --hot run src/server.ts",
    "reflect": "bash scripts/reflect.sh",
    "gen-icons": "bun scripts/gen-icons.ts",
    "install-extension": "bash scripts/install-extension.sh",
    "test:unit": "bun test src/server.test.ts",
    "test": "bunx playwright test",
    "embed:all": "bun scripts/embed-all.ts",
    "lint": "eslint src/ web/ --ext .ts,.tsx",
    "check": "tsc --noEmit && eslint src/ web/ --ext .ts,.tsx && bun test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-orm": "^0.45.2",
    "linkedom": "^0.18.12",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sqlite-vec": "^0.1.9",
    "youtube-transcript": "^1.3.0"
  }
}
