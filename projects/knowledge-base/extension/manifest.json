{
  "manifest_version": 3,
  "name": "Knowledge Base",
  "version": "1.0",
  "description": "Save YouTube videos and web pages to your local knowledge base",
  "permissions": ["activeTab", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
