{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/riseof/environment/.claude/hooks/testing-gate/on-code-edit.sh",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/riseof/environment/.claude/hooks/testing-gate/on-bash.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/riseof/environment/.claude/hooks/agent-spawn-guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/riseof/environment/.claude/hooks/testing-gate/stop-gate.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
